        <item>
            <title>0.1.6</title>
            <pubDate>Wed, 15 Jul 2026 11:35:31 -0700</pubDate>
            <link>https://krehin.com/</link>
            <sparkle:version>6</sparkle:version>
            <sparkle:shortVersionString>0.1.6</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
            <description sparkle:format="markdown"><![CDATA[- The post list is now a single sidebar you can reliably show or hide with the toolbar toggle (or View menu), collapsing to a clean editor. All/Drafts/Published moved into a segmented control at the top of the list.
]]></description>
