        </item>
        <item>
            <title>0.1.5</title>
            <pubDate>Wed, 15 Jul 2026 11:10:21 -0700</pubDate>
            <link>https://krehin.com/</link>
            <sparkle:version>5</sparkle:version>
            <sparkle:shortVersionString>0.1.5</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
            <description sparkle:format="markdown"><![CDATA[- Fixed the sidebar toolbar: two clear controls instead of three. The system button shows or hides the filter sidebar, and the new button collapses the post list down to just the editor.
]]></description>
            <enclosure url="https://github.com/jwold/krehin/releases/download/v0.1.5/Krehin-0.1.5.zip" length="1405970" type="application/octet-stream" sparkle:edSignature="U5A3TuYzVpttGQ3O2hDIbzhzk2emo8ebBVKKtYTPg0eM3Fj+x2oTjG6D+F8Nd+eCmttsWwaXBe3vFp+CWiBZDw=="/>
        </item>
        <item>
            <title>0.1.4</title>
            <pubDate>Wed, 15 Jul 2026 10:41:28 -0700</pubDate>
            <link>https://krehin.com/</link>
            <sparkle:version>4</sparkle:version>
            <sparkle:shortVersionString>0.1.4</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
            <description sparkle:format="markdown"><![CDATA[- Krehin now opens straight into a new draft, so you can start writing right away.
- The filter sidebar and post list tuck away for a clean, focused editor, and toggle back from the toolbar.
- The editor blends into the window instead of sitting on a hard black panel.
- A simpler, refreshed app icon.
]]></description>
            <enclosure url="https://github.com/jwold/krehin/releases/download/v0.1.4/Krehin-0.1.4.zip" length="1408356" type="application/octet-stream" sparkle:edSignature="NeEH4oN8gJN7bJKUUPMsJul11Q/KaZirl6ivYaAGJdznxdg/9Grp5yA7N4IWpCmuxHTI4JasyzgpoYfziE6bBA=="/>
        </item>
